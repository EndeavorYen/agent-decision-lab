{
  "name": "agent-decision-lab",
  "version": "0.2.0",
  "description": "Local-first CLI for branching AI development experiments.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/EndeavorYen/agent-decision-lab.git"
  },
  "homepage": "https://github.com/EndeavorYen/agent-decision-lab#readme",
  "bugs": {
    "url": "https://github.com/EndeavorYen/agent-decision-lab/issues"
  },
  "keywords": [
    "agent",
    "ai",
    "cli",
    "decision-tree",
    "experiments",
    "git-worktree"
  ],
  "bin": {
    "adl": "./bin/adl.js"
  },
  "files": [
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "bin/",
    "docs/",
    "src/"
  ],
  "scripts": {
    "test": "node --test tests/*.test.js",
    "smoke": "node tests/smoke-runner.mjs",
    "coverage": "node --test --experimental-test-coverage tests/*.test.js",
    "privacy": "node bin/adl.js privacy audit --public-files --json",
    "verify": "npm test && npm run smoke && npm run privacy && git diff --check && npm pack --dry-run"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
